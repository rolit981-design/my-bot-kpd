# --- Вспомогательные функции ---
def get_user(uid):
    if uid not in user_data:
        user_data[uid] = {'rank': 0, 'warns': [], 'mute_until': None}
    return user_data[uid]

# --- Команды модерации ---

@dp.message(Command("повысить"))
async def promote(message: types.Message):
    admin = get_user(message.from_user.id)
    if admin['rank'] < 4: return # Только высокие ранги
    
    if not message.reply_to_message: return
    target_id = message.reply_to_message.from_user.id
    target = get_user(target_id)
    
    if target['rank'] < 5:
        target['rank'] += 1
        await message.reply(f"{HEROES['hiccup']} Поздравляю, теперь твой ранг: {target['rank']}!")

@dp.message(F.text.lower().startswith("варн"))
async def set_warn(message: types.Message):
    admin = get_user(message.from_user.id)
    if admin['rank'] < 1: return
    
    if not message.reply_to_message: return
    target_id = message.reply_to_message.from_user.id
    target = get_user(target_id)
    
    # Логика иерархии
    if admin['rank'] <= target['rank']:
        return await message.reply(f"{HEROES['astrid']} Ты не можешь наказывать всадника своего уровня или выше!")

    target['warns'].append(datetime.now() + timedelta(days=1))
    count = len(target['warns'])
    
    if count >= chat_config["warn_limit"]:
        await bot.ban_chat_member(message.chat.id, target_id)
        await message.answer(f"{HEROES['astrid']} Лимит превышен! Нарушитель изгнан с Олуха.")
    else:
        await message.answer(f"{HEROES['astrid']} Предупреждение выдано! ({count}/{chat_config['warn_limit']})")

