    status = "Обычный участник" if user['rank'] == 0 else f"Модератор {user['rank']} ранга"
    await message.reply(f"{HEROES['fishlegs']} Хм, дай-ка свериться с книгой... Твой ранг: {user['rank']} ({status}). Варнов: {len(user['warns'])}")

