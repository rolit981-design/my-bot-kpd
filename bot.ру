GIF_URL = 'https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJueGZ3bmZ4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/ASd0WB6uEvs0S0L8bi/giphy.gif'

@bot.message_handler(content_types=['new_chat_members'])
def welcome(message):
    for user in message.new_chat_members:
        # Проверяем, что зашел человек, а не сам бот
        if user.id != bot.get_me().id:
            text = f"Привет, {user.first_name}! Добро пожаловать!"
            bot.send_animation(message.chat.id, GIF_URL, caption=text)

bot.infinity_polling()
